    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.6",
    "jsdom": "^27.0.1",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": "^22.0.0 || >=24.0.0"
  },
  "dependencies": {
    "botid": "^1.5.11",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
