{
  "name": "guandan-online-codex",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Real online multiplayer Guandan (掼蛋) — landscape-first card game",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
